// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client"
    output = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id                  String      @id         @default(uuid())
    username            String
    password            String
    orders              Order[]     @relation("userOrders")
    maker_fills         Fill[]      @relation("maker_user")
    taker_fills         Fill[]      @relation("taker_user")
}

model Market {
    id                  String      @id         @default(uuid())
    slug                String      @unique
    imageUrl            String
}

model Order {
    id                  String       @id        @default(uuid())
    userId              String
    market_id           String
    orderType           OrderType
    side                Side
    price               String
    slippage            Int
    qty                 String
    filledQty           String
    initialMargin       String
    status              OrderStatus
    createdAt           DateTime    @default(now()) 
    updatedAt           DateTime    @updatedAt
    maker_fills         Fill[]      @relation("maker")
    taker_fills         Fill[]      @relation("taker")
    user                User        @relation("userOrders", fields: [userId], references: [id], onDelete: Cascade)
}

model Fill {
    id                  String      @id         @default(uuid())
    maker_id            String
    taker_id            String
    qty                 String
    price               String
    maker_order_id      String
    taker_order_id      String
    market_id           String
    createdAt           DateTime    @default(now())
    maker_order         Order       @relation("maker", fields: [maker_order_id], references: [id])
    taker_order         Order       @relation("taker", fields: [taker_order_id], references: [id])
    maker_user          User        @relation("maker_user", fields: [maker_id], references: [id])
    taker_user          User        @relation("taker_user", fields: [taker_id], references: [id])
}

enum OrderStatus {
    Filled
    PartiallyFilled
    Cancelled
    Open
}

enum Side {
    Bid
    Ask
}

enum OrderType {
    Market
    Limit
}